                        kind @status
                        text "Doing → Done (nplan complete)"
                    }
                )
            }

            {
                id w1-structures
                title "sem pass: structures/dynarray/stack/int_stack/stringhash/trie/mem (120 data-structure functions)"
                sealed true
                log (
                    {
                        at 2026-07-03T15:10:24.105478Z
                        author "brendan@necessary.nu"
                        kind @status
                        text "Doing → Done (nplan complete)"
                    }
