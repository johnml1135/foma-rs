                title "sem pass: io/lexcread/lexc/flookup/cgflookup (76 IO and lexc functions)"
                sealed true
                log (
                    {
                        at 2026-07-03T15:10:24.284118Z
                        author "brendan@necessary.nu"
                        kind @status
                        text "Doing → Done (nplan complete)"
                    }
                )
            }

            {
                id w1-rewrite-flags-define
                title "sem pass: rewrite/flags/define (40 rewrite-rule and flag functions)"
                sealed true
                log (
                    {
                        at 2026-07-03T15:10:24.305672Z
                        author "brendan@necessary.nu"
                        kind @status
                        text "Doing → Done (nplan complete)"
                    }
                )
            }
        )
    }

    {
        id wave-2-translate
        title "Wave 2: translate — 1:1 bug-for-bug Rust port of all 1020 symbols"
        children (
            {
                id w2-scaffold
                title "Cargo workspace, core header types (fsm/sigma/apply handles), porting conventions"
                sealed true
                log (
                    {
                        at 2026-07-03T15:30:20.396846Z
                        author "brendan@necessary.nu"
                        kind @status
                        text "Doing → Done (nplan complete)"
                    }
                )
            }

            {
                id w2-base-utils
                title "Translate mem, utf8, int_stack, stringhash, trie, sigma"
                deps (w2-scaffold)
                sealed true
                log (
                    {
                        at 2026-07-03T15:46:11.763013Z
